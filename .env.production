# Production Environment Variables for AWS EC2 Deployment
# Replace the DATABASE_URL with your actual RDS endpoint and credentials

# Database Configuration (Replace with your RDS endpoint)
DATABASE_URL=postgresql://dbadmin:your_secure_password@your-rds-endpoint.region.rds.amazonaws.com:5432/url_shortener

# Application Configuration
PORT=8000
PYTHONPATH=/app

# Production Settings
DEBUG=false
LOG_LEVEL=info